# RepoEval Environment Variables
REPOEVAL_DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/repoeval
REPOEVAL_REDIS_URL=redis://localhost:6379/0
REPOEVAL_GITHUB_CLIENT_ID=your_github_client_id
REPOEVAL_GITHUB_CLIENT_SECRET=your_github_client_secret
REPOEVAL_GITHUB_REDIRECT_URI=http://localhost:8000/api/auth/callback
REPOEVAL_FRONTEND_URL=http://localhost:3000
REPOEVAL_DEBUG=true
